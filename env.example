# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Configuration (Configurable for self-hosted LLM)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o

# Vision/OCR Configuration
USE_VISION_API=true
VISION_MODEL=gpt-4o

# AI Questioning Feature (see QUESTIONING_CONFIG.md)
# Set to true to enable AI-generated follow-up questions between parties
ENABLE_AI_QUESTIONING=false

# Maximum number of questioning rounds (default: 2)
MAX_QUESTIONING_ROUNDS=2

# Number of questions to generate per party per round (default: 3)
QUESTIONS_PER_PARTY=3

# Automatically advance to judgment after questions are answered (default: true)
AUTO_ADVANCE_TO_JUDGMENT=true

# Rate Limiting (optional, for Upstash Redis)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=
